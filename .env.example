# =====================================================================
# SCOUTT — environment variables (Vercel + local dev)
# =====================================================================
# Only ELEVENLABS_API_KEY is strictly required for the "Listen" button.
# Everything else is optional — the app gracefully falls back to demo
# data when keys are missing. The Anakin key is provided by the user
# at runtime via the in-app "Enter API Key" modal.
# =====================================================================

# ---- Supabase (optional) ----------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001

# ---- NVIDIA NIM (REQUIRED for live mode) ------------------------------
# Used in TWO places:
#   1) "Ask SCOUTT" chat answers.
#   2) The reshape step that converts raw Anakin Agentic-Search output
#      into the dashboard payload shape. Without this key, "live" mode
#      is impossible — the app will fall back to demo data.
# Get one at https://build.nvidia.com/meta/llama-3.2-3b-instruct
NVIDIA_API_KEY=

# ---- Anakin Agentic Search --------------------------------------------
# LEAVE BLANK on Vercel. End-users paste their own key in the UI
# ("Enter API Key" → modal). The frontend sends it as X-Anakin-Key.
ANAKIN_API_KEY=

# ---- ElevenLabs Text-to-Speech (optional) -----------------------------
# Powers the "Listen" button. Without this, browser SpeechSynthesis is used.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ---- App --------------------------------------------------------------
NODE_ENV=development
PORT=3000
