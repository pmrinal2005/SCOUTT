{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**", "public/**"]
      }
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/api/index.ts" },
    { "src": "/favicon.ico", "dest": "/api/index.ts" },
    { "src": "/favicon.svg", "dest": "/api/index.ts" },
    { "src": "/favicon.png", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/api/index.ts" }
  ]
}
