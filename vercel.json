{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "echo no-build",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@5.1.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/static/(.*)", "destination": "/static/$1" },
    { "source": "/favicon.ico", "destination": "/static/favicon.svg" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
