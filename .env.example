# =====================================================================
# SCOUTT — environment variables
# Copy to .env.local for local dev. Add the same vars on Vercel
# (Project Settings → Environment Variables).
#
# Only ELEVENLABS_API_KEY is strictly required for the "Listen" button.
# Everything else is optional — the app gracefully falls back to demo
# data when keys are missing. The Anakin key is provided by the user
# at runtime via the in-app "Enter API Key" modal.
# =====================================================================

# ---- Supabase (optional — leave blank to use in-memory demo data) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Demo tenant id (only used when Supabase is wired up) ----
DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001

# ---- NVIDIA NIM (optional — powers "Ask SCOUTT" when no Anakin key) ----
NVIDIA_API_KEY=

# ---- Anakin Agentic Search ----
# LEAVE BLANK on Vercel. End-users paste their own key in the UI
# ("Enter API Key" → modal). The frontend sends it as X-Anakin-Key.
# Only set this server-side if you want a shared default key for
# logged-out demo visitors.
ANAKIN_API_KEY=

# ---- ElevenLabs Text-to-Speech (REQUIRED for "Listen" button) ----
# Get one at https://elevenlabs.io/app/settings/api-keys
# The TTS proxy lives at /api/tts. If unset, the UI falls back to the
# browser's native SpeechSynthesis API automatically.
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional ElevenLabs voice override (default: George — JBFqnCBsd6RMkjVDRZzb)
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ---- App ----
NODE_ENV=development
PORT=3000
